# --- LLM backend ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120

# --- Embeddings (local, free, always used regardless of LLM_PROVIDER) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- RAG tuning ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4

# --- SQL safety ---
MAX_SQL_ROWS=500

# --- Paths (relative to project root; defaults are usually fine) ---
DB_PATH=data/hospital.db
DOCS_DIR=docs
VECTORSTORE_DIR=vectorstore
LOGS_DIR=logs